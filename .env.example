# ==========================================================
# AKA — environment template. Copy to .env and fill in values.
# Do NOT wrap values in quotes (docker compose env_file keeps quotes literally).
# ==========================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
# In docker compose this is overridden to include the "backend" service host.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Frontend origin (CORS; not needed when served same-origin via nginx) ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Qdrant ---
# For local (non-docker) runs use localhost. docker compose overrides host to "qdrant".
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=aka_knowledge

# --- Embeddings (HuggingFace sentence-transformers; baked into the backend image) ---
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768

# --- LLM (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
