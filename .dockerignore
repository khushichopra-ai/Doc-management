# Root build context — keep it small and never bake local state / secrets.
.git
.gitignore
*.md

# Python
**/__pycache__/
**/*.py[cod]
*.log
venv/
.venv/
backend/venv/

# Local DB (created/seeded inside the container)
backend/db.sqlite3
backend/db.sqlite3-*

# Node / frontend build artifacts (frontend is built inside the image)
frontend/node_modules/
frontend/dist/

# Secrets — provided at runtime via docker compose env_file / -e
.env
.env.*

# Editor / scratch
.vscode/
.idea/
